# Y2K Pixel Blog - Environment Configuration
# Copy this file to .env and update values

# Database
DATABASE_URL=postgres://blog:blog@localhost:5432/y2k_blog?sslmode=disable

# Server
PORT=8080

# JWT
JWT_SECRET=y2k-pixel-blog-change-me-in-production

# CORS (frontend dev server)
CORS_ORIGIN=http://localhost:3000

# AI Summary (OpenAI-compatible API)
AI_API_URL=
AI_API_KEY=
AI_MODEL=deepseek-chat

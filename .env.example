# Y2K Pixel Blog — Environment Configuration
# Copy to .env and edit:  cp .env.example .env

# ============ Database ============
DB_USER=blog
DB_PASSWORD=change-me-strong-password

# ============ Security ============
# REQUIRED: Generate with: openssl rand -base64 32
JWT_SECRET=

# ============ Domains ============
# Set these to your actual domains (also configure in admin panel Settings)
# FRONTEND_DOMAIN=blog.example.com
# ADMIN_DOMAIN=admin.example.com

# CORS — additional allowed origins (comma-separated, optional)
# Domains from DB are auto-added, this is for extras
# CORS_ORIGINS=https://extra.example.com

# ============ API URLs ============
# Frontend → API (used during Docker build, baked into SSR bundle)
API_URL=http://api:8080

# Admin → API (relative path works when Nginx proxies /api/)
ADMIN_API_URL=/api

# ============ AI Summary ============
# OpenAI-compatible API for post summaries
AI_API_URL=
AI_API_KEY=
AI_MODEL=deepseek-chat

# ============ SSL ============
# SSL is configured in the admin panel, not here.
# For autocert (Let's Encrypt), ensure port 80 is publicly accessible.
# ACME_CACHE_DIR is automatically set to /app/certs in Docker.
